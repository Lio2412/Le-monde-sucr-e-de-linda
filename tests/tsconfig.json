{
  "extends": "../frontend/tsconfig.json",
  "compilerOptions": {
    "types": ["node", "jest", "@testing-library/jest-dom"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../frontend/src/*"],
      "@test-utils/*": ["./utils/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../frontend/src/**/*.ts",
    "../frontend/src/**/*.tsx",
    "./unit/**/*",
    "./integration/**/*",
    "./api/**/*",
    "./e2e/**/*"
  ],
  "exclude": [
    "node_modules",
    "coverage"
  ]
} 