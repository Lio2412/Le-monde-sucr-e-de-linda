{
  "name": "le-monde-sucre-de-linda-backend",
  "version": "1.0.0",
  "description": "Backend pour Le Monde Sucré de Linda",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/server.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "test": "jest --config ../tests/setup/backend.jest.config.mjs",
    "test:watch": "jest --config ../tests/setup/backend.jest.config.mjs --watch",
    "test:coverage": "jest --config ../tests/setup/backend.jest.config.mjs --coverage",
    "db:test:setup": "cross-env NODE_ENV=test tsx scripts/setup-test-db.ts",
    "test:setup": "npm run db:test:setup && prisma migrate deploy",
    "test:verify-env": "cross-env NODE_ENV=test tsx scripts/verify-test-env.ts",
    "test:init": "npm run test:verify-env && npm run test:setup",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dotenv": "^6.1.1",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@babel/plugin-transform-typescript": "^7.26.7",
    "@babel/preset-env": "^7.26.7",
    "@babel/preset-typescript": "^7.26.0",
    "@jest/globals": "^29.7.0",
    "@prisma/client": "^6.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.17.16",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.2",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "pg": "^8.13.1",
    "prisma": "^6.3.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
