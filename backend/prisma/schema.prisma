// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecipeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum RecipeCategory {
  STARTER
  MAIN
  DESSERT
  DRINK
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  recipes   Recipe[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
}

model Recipe {
  id             String           @id @default(uuid())
  slug           String           @unique
  title          String
  description    String
  mainImage      String?
  preparationTime Int
  cookingTime    Int
  difficulty     RecipeDifficulty
  servings       Int
  category       RecipeCategory
  tags           String[]
  ingredients    Ingredient[]
  steps          Step[]
  author         User             @relation(fields: [authorId], references: [id])
  authorId       String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([authorId])
  @@index([category])
  @@index([difficulty])
  @@index([slug])
  @@index([title])
}

model Ingredient {
  id       String  @id @default(uuid())
  name     String
  quantity Float
  unit     String
  recipe   Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  @@index([recipeId])
  @@index([name])
}

model Step {
  id          String  @id @default(uuid())
  order       Int
  description String
  duration    Int
  image       String?
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId    String

  @@index([recipeId])
  @@index([order])
}

model RecipeShare {
  id            String   @id @default(cuid())
  comment       String
  rating        Int
  imagePath     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  recipe        Recipe   @relation(fields: [recipeId], references: [id])
  recipeId      String
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  likes         Like[]
  notifications Notification[]
}

model Like {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  share     RecipeShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  shareId   String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([shareId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // LIKE, COMMENT, etc.
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  shareId   String?
  recipeId  String?
  share     RecipeShare? @relation(fields: [shareId], references: [id], onDelete: SetNull)
  recipe    Recipe?      @relation(fields: [recipeId], references: [id], onDelete: SetNull)
} 