# Configuration de la base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/le_monde_sucre

# Configuration du serveur
PORT=3001
NODE_ENV=development

# JWT (JSON Web Token)
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Limites de l'API
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Configuration des logs
LOG_LEVEL=debug

# Email (pour les futures fonctionnalités)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Stockage des images (pour les futures fonctionnalités)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET= 